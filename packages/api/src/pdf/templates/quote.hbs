<html>

<head>

    <meta http-equiv="Content-Type" content="text/html; charset=utf-8"/>

    <style>
        {{{css}}}
    </style>
</head>

<body>

    <div id="content">

        <table>
            <tr>
                <td style="vertical-align: top;">
                    <p>{{client.name}}</p>
                    <p>{{{client.address}}}</p>
                </td>
                <td style="text-align: right;">
                    <p>Wien, am {{date}}</p>
                </td>
            </tr>
        </table>

        <table cellpadding="0" cellspacing="0" style="margin-top: 50px;">
            <thead>
                <tr>
                    <th style="text-align: left;">{{project.name}}</th>
                    {{#if showHours}}
                    <th style="width: 100px;">Stunden</th>
                    {{/if}}
                    <th style="width: 100px;">Betrag</th>
                </tr>
            </thead>
            <tbody>
                {{#each tasks}}
                <tr class="task">
                    <td style="text-align: left;">
                        {{{this.name}}}
                        {{#if this.note}}
                            <p class="task-note">{{{this.note}}}</p>
                        {{/if}}
                    </td>
                    {{#if ../showHours}}
                    <td>{{this.duration}}</td>
                    {{/if}}
                    <td>&euro;{{this.cost}}</td>
                </tr>
                {{/each}}
            </tbody>
        </table>

        <table style="page-break-inside: avoid;" cellpadding="0" cellspacing="0">
            {{#unless reverseCharge}}
            <tr class="netto">
                <td style="text-align: left;">Nettobetrag</td>
                {{#if showHours}}
                <td style="width: 100px;">{{totalDuration}}</td>
                {{/if}}
                <td style="width: 100px;">&euro;{{totalCost}}</td>
            </tr>
            <tr class="tax">
                <td style="text-align: left;">20% USt.</td>
                {{#if showHours}}
                <td></td>
                {{/if}}
                <td>&euro;{{tax}}</td>
            </tr>
            {{/unless}}
            <tr class="total">
                <td style="text-align: left;">Gesamtsumme</td>
                {{#if showHours}}
                <td style="width: 100px;"></td>
                {{/if}}
                <td style="width: 100px;">&euro;{{total}}</td>
            </tr>
        </table>

    </div>

</body>

</html>
