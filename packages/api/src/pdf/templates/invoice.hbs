<html>

<head>

    <meta http-equiv="Content-Type" content="text/html; charset=utf-8"/>

    <style>
        {{{css}}}
    </style>
</head>

<body>

    <div id="content">

        <table class="pdf-address">
            <tr>
                <td style="vertical-align: top;">
                    <p>{{invoice.clientName}}</p>
                    <p>{{{invoice.clientAddress}}}</p>
                    {{#if invoice.clientVatNumber}}
                        <p>UID: {{invoice.clientVatNumber}}</p>
                    {{/if}}
                </td>
                <td style="text-align: right;">
                    <p>Wien, am {{invoice.sentAt}}</p>
                    <p>Fällig am: {{invoice.dueDate}}</p>
                </td>
            </tr>
            {{#if invoice.reverseCharge}}
                <tr>
                    <td colspan="2">
                        <p>Reverse Charge - Übergang der Steuerschuld auf den Leistungsempfänger</p>
                    </td>
                </tr>
            {{/if}}
            {{#if invoice.note}}
                <tr>
                    <td colspan="2">
                        <p>{{invoice.note}}</p>
                    </td>
                </tr>
            {{/if}}
        </table>

        {{#each projects}}
        <table cellpadding="0" cellspacing="0" style="margin-top: 50px;">
            <thead>
                <tr>
                    <th style="text-align: left;">{{this.name}}</th>
                    {{#if ../invoice.showDate}}
                    <th style="width: 100px;">Datum</th>
                    {{/if}}
                    {{#if ../invoice.showHours}}
                    <th style="width: 100px;">Stunden</th>
                    {{/if}}
                    <th style="width: 100px;">Betrag</th>
                </tr>
            </thead>
            <tbody>
                {{#each this.tasks}}
                <tr class="task">
                    <td style="text-align: left;">
                        {{{this.name}}}
                        {{#if this.note}}
                            <p class="task-note">{{{this.note}}}</p>
                        {{/if}}
                    </td>
                    {{#if ../../invoice.showDate}}
                    <td>{{this.date}}</td>
                    {{/if}}
                    {{#if ../../invoice.showHours}}
                    <td>{{this.duration}}</td>
                    {{/if}}
                    <td>&euro;{{this.cost}}</td>
                </tr>
                {{/each}}
            </tbody>
        </table>
        {{/each}}

        <table style="page-break-inside: avoid;" cellpadding="0" cellspacing="0">
            {{#unless invoice.reverseCharge}}
                <tr class="netto">
                    <td style="text-align: left;">Nettobetrag</td>
                    {{#if invoice.showDate}}<td style="width: 100px;"></td>{{/if}}
                    {{#if invoice.showHours}}<td style="width: 100px;">{{totalDuration}}</td>{{/if}}
                    <td style="width: 100px;">&euro;{{totalCost}}</td>
                </tr>
                <tr class="tax">
                    <td style="text-align: left;">20% USt.</td>
                    {{#if invoice.showDate}}<td></td>{{/if}}
                    {{#if invoice.showHours}}<td></td>{{/if}}
                    <td>&euro;{{tax}}</td>
                </tr>
            {{/unless}}
            <tr class="total">
                <td style="text-align: left;">Gesamtsumme</td>
                {{#if invoice.showDate}}<td style="width: 100px;"></td>{{/if}}
                {{#if invoice.showHours}}
                <td style="width: 100px;">
                    {{#if invoice.reverseCharge}}{{totalDuration}}{{/if}}
                </td>
                {{/if}}
                <td style="width: 100px;">&euro;{{total}}</td>
            </tr>
        </table>

    </div>

</body>

</html>
