FROM node:20-alpine

# Chromium for Puppeteer PDF generation
RUN apk add --no-cache chromium
ENV PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
ENV PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

WORKDIR /app

RUN corepack enable && corepack prepare pnpm@11.0.5 --activate

# Copy monorepo root files
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./

# Copy package-level package.json
COPY packages/api/package.json ./packages/api/

# Install dependencies (cached layer)
RUN pnpm install --frozen-lockfile

# Copy API source
COPY packages/api/ ./packages/api/

WORKDIR /app/packages/api

EXPOSE 3000

# Runtime install uses the volume-mounted lockfile (see docker-compose.yml).
# `--frozen-lockfile` would break dev workflow when adding deps locally;
# `--prefer-frozen-lockfile` keeps reinstalls fast when nothing changed.
CMD ["sh", "-c", "pnpm install --prefer-frozen-lockfile && pnpm migration:run && pnpm start:dev"]
