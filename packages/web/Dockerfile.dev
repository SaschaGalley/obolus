FROM node:20-alpine

WORKDIR /app

RUN corepack enable && corepack prepare pnpm@11.0.5 --activate

# Copy monorepo root files
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./

# Copy package-level package.json
COPY packages/web/package.json ./packages/web/

# Install dependencies (cached layer)
RUN pnpm install --frozen-lockfile

# Copy web source
COPY packages/web/ ./packages/web/

WORKDIR /app/packages/web

EXPOSE 5173

# Re-resolve deps at boot so adding/removing packages doesn't require a rebuild
# (root files are volume-mounted from the host – see docker-compose.yml).
CMD ["sh", "-c", "pnpm install --prefer-frozen-lockfile && pnpm dev --host"]
